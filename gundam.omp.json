{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "upgrade": {
    "source": "cdn",
    "interval": "168h",
    "auto": false,
    "notice": false
  },
  "console_title_template": "{{if .Root}}⚡ {{end}}{{.Folder}}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "leading_diamond": "\u250c",
      "segments": [
        {
          "options": {
            "windows": "\uf17a"
          },
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}}  \ue0bd ",
          "foreground": "#7eb8da",
          "type": "os",
          "style": "plain"
        },
        {
          "options": {
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": "[<#ffffff>{{ .UpstreamIcon }}</> {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} <#ffffff>\uf044</> {{.Working.String}}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }}|{{ end }}{{ if .Staging.Changed }} <#ffffff>\uf046</> {{.Staging.String}}{{ end }}{{ if gt .StashCount 0 }} <#ffffff>\ueb4b</> {{.StashCount}}{{ end }}{{ if gt .WorktreeCount 0 }} <#ffffff>\uf1bb</> {{.WorktreeCount}}{{ end }}]",
          "foreground": "#4caf50",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#ed1941{{ end }}",
            "{{ if or (gt .Ahead 0) (gt .Behind 0) }}#2196f3{{ end }}"
          ],
          "type": "git",
          "style": "plain"
        }
      ],
      "trailing_diamond": "\ue0b0",
      "newline": true
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": " \uf26c  {{ if .SSHSession }}\ueba9  {{ end }}{{ .UserName }}@{{ .HostName }} \ue0bd ",
          "foreground": "#000000",
          "powerline_symbol": "\ue0b0",
          "background": "#e0e0e0",
          "type": "session",
          "style": "powerline"
        },
        {
          "options": {
            "style": "full"
          },
          "template": " {{ path .Path .Location }} ",
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0bc",
          "background": "#000080",
          "type": "path",
          "style": "powerline"
        },
        {
          "options": {
            "always_enabled": true
          },
          "template": " \uf064  {{ .FormattedMs }} \ue0bd ",
          "foreground": "#fffef9",
          "powerline_symbol": "\ue0bc",
          "background": "#33a3dc",
          "type": "executiontime",
          "style": "powerline"
        },
        {
          "options": {
            "always_enabled": true
          },
          "template": " \uf12a >>{{ if gt .Code 0 }}{{ reason .Code }}{{ else }}OK{{ end }} \ue0bd ",
          "foreground": "#003300",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#ffffff{{ end }}"
          ],
          "powerline_symbol": "\ue0bc",
          "background": "#87ceeb",
          "background_templates": [
            "{{ if gt .Code 0 }}#cc3333{{ end }}"
          ],
          "type": "status",
          "style": "powerline"
        }
      ],
      "newline": true
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": "\u2514",
          "foreground": "#e0e0e0",
          "type": "text",
          "style": "plain"
        },
        {
          "template": " $",
          "foreground": "#ffffff",
          "type": "text",
          "style": "plain"
        }
      ],
      "newline": true
    }
  ],
  "version": 4,
  "final_space": true
}
